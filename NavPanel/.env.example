# --- Signaling server (required in production) ---
# Your Render Web Service URL, e.g. https://video-chat-signaling.onrender.com
# No trailing slash. Must match the URL Render shows for the service.
VITE_BACKEND_URL=

# --- Firebase (Google auth) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- WebRTC (optional) ---
# JSON array of RTCIceServer objects. If unset, default public Google STUN is used.
# For stricter NAT, add a TURN provider here.
# VITE_WEBRTC_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"stun:stun1.l.google.com:19302"}]
