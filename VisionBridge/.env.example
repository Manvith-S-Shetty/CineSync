# Render (and other hosts) set PORT automatically — do not hardcode in production.
PORT=5000

# Bind address (Render expects 0.0.0.0)
HOST=0.0.0.0

# Required for production: comma-separated frontend origins (no trailing slashes)
# Example (Vercel):
# CORS_ORIGIN=https://your-app.vercel.app
# Multiple:
# CORS_ORIGIN=https://your-app.vercel.app,https://www.yourdomain.com

# Optional: Node environment
# NODE_ENV=production
