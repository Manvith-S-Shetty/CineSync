# Signaling server URL for Socket.IO.
# Examples:
# - Local dev on this machine: http://localhost:5000
# - Mobile/LAN test (same machine running signaling server): http://192.168.1.10:5000
#
# If you leave this unset, the app will auto-detect the current page hostname
# and connect to http://<current-host>:5000 (fallback: http://localhost:5000).
VITE_BACKEND_URL=

# Firebase (Google sign-in). Copy from Firebase Console → Project settings → Your apps.
# Without these, the app loads but sign-in stays disabled until .env is configured.
VITE_FIREBASE_API_KEY=AIzaSyBSGR_gkGQoRlf-ydC7ASr1v3BEsSrefmA
VITE_FIREBASE_AUTH_DOMAIN=cinesync-4568f.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=cinesync-4568f
VITE_FIREBASE_STORAGE_BUCKET=cinesync-4568f.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=330196288017
VITE_FIREBASE_APP_ID=1:330196288017:web:c5b61a3f7709c823df27b0

